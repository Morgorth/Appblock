<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <!-- Blocked app icon -->
        <ImageView
            android:id="@+id/iv_blocked_app_icon"
            android:layout_width="@dimen/app_icon_size_large"
            android:layout_height="@dimen/app_icon_size_large"
            android:layout_marginTop="@dimen/spacing_xl"
            android:layout_marginBottom="@dimen/spacing_md"
            android:src="@android:drawable/sym_def_app_icon" />

        <!-- Blocked app name -->
        <TextView
            android:id="@+id/tv_blocked_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:textColor="@color/on_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Profile name -->
        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />

        <!-- Block end time -->
        <TextView
            android:id="@+id/tv_block_end_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Go Back button (prominent) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_go_back"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_button_height"
            android:layout_marginBottom="@dimen/spacing_md"
            android:text="@string/go_back"
            android:textSize="18sp"
            android:backgroundTint="@color/on_primary"
            android:textColor="@color/primary" />

        <!-- Emergency Override button (less prominent) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_emergency_override"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/emergency_override"
            android:textSize="14sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#80FFFFFF" />

        <!-- Override container (shown/hidden) -->
        <LinearLayout
            android:id="@+id/override_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_override_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/override_prompt"
                android:textColor="@color/on_background"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_justification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/justification_hint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:maxLines="6" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tv_justification_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm_override"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/confirm_override"
                android:enabled="false"
                android:backgroundTint="@color/secondary" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
