<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="@dimen/spacing_xs">

    <!-- Day toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_day_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/on_background"
            android:textSize="16sp" />

        <!--
            Visible only when the day is enabled.
            "Sync"   = this day shares the global time window (default).
            "Custom" = this day has its own independent time window.
            Tapping it toggles between the two modes.
        -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_custom"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:text="@string/schedule_sync"
            android:textSize="11sp"
            android:visibility="gone"
            app:chipMinHeight="32dp"
            app:chipStartPadding="8dp"
            app:chipEndPadding="8dp"
            style="@style/Widget.MaterialComponents.Chip.Action" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_day_enabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Time pickers (shown only when day is enabled) -->
    <LinearLayout
        android:id="@+id/time_pickers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="@dimen/spacing_sm"
        android:paddingStart="@dimen/spacing_sm"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_time"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tv_start_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:00"
            android:textSize="14sp"
            android:layout_marginEnd="@dimen/spacing_md"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/end_time"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/spacing_sm" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tv_end_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="17:00"
            android:textSize="14sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

</LinearLayout>
