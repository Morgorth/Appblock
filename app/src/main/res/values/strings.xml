    <!-- Accessibility service -->
    <string name="accessibility_service_label">FocusLock App Blocker</string>
    <string name="accessibility_service_description">FocusLock uses accessibility events as a fallback mechanism to detect when a blocked app is opened, especially on devices where usage stats may be restricted.</string>

