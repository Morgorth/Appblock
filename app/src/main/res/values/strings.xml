    <string name="onboarding_usage_stats_title">Allow Usage Access</string>
    <string name="onboarding_usage_stats_desc">FocusLock needs permission to see which app is in the foreground so it can enforce your blocking schedules.\n\nTap the button below, find FocusLock in the list, and enable access.</string>
    <string name="onboarding_overlay_title">Allow Drawing Over Apps</string>
    <string name="onboarding_overlay_desc">FocusLock needs permission to draw a block screen on top of apps you\'ve chosen to block.\n\nTap the button below and enable \'Allow display over other apps\' for FocusLock.</string>
    <string name="onboarding_accessibility_title">Enable Accessibility Service (Recommended)</string>
    <string name="onboarding_accessibility_desc">The accessibility service provides a second layer of protection — especially useful on Xiaomi, Huawei, and other devices that may restrict background app monitoring.\n\nThis step is optional but strongly recommended for reliable blocking.</string>
    <string name="onboarding_battery_title">Disable Battery Optimization</string>
    <string name="onboarding_battery_desc">%s devices sometimes stop background apps to save battery. To ensure FocusLock keeps running, please whitelist it from battery optimization.</string>
