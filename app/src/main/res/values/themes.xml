<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FocusLock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Dark surfaces -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/on_background</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Status bar blends into background -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Soft periwinkle ripple -->
        <item name="colorControlHighlight">@color/primary_glow</item>

        <!-- Seamless dark toolbar — no colored bar -->
        <item name="toolbarStyle">@style/Widget.FocusLock.Toolbar</item>

        <!-- Rounded buttons -->
        <item name="materialButtonStyle">@style/Widget.FocusLock.Button</item>
    </style>

    <!-- Toolbar: blends into background, title uses primary periwinkle -->
    <style name="Widget.FocusLock.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
    </style>

    <!-- Rounded pill buttons -->
    <style name="Widget.FocusLock.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <!-- Overlay activity: no title bar, full screen -->
    <style name="Theme.FocusLock.Overlay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/overlay_background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="materialButtonStyle">@style/Widget.FocusLock.Button</item>
    </style>
</resources>
